    <CraftRecipe>
      <CostItem>
        <DefName>Label</DefName>
        <Amount>2</Amount>
      </CostItem>
    </CraftRecipe>
    <IconPath>Textures/Items/Resource/coal</IconPath>
  </ItemData>

